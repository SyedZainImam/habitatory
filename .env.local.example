# Sanity CMS Configuration
# Get these from https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity Write Token (required for contact form submissions)
# Generate at: https://www.sanity.io/manage → API → Tokens → Add API Token (Editor role)
SANITY_API_WRITE_TOKEN=your_write_token_here
